<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GustoPOS.Views.BillingPage"
             BackgroundColor="#F8F9FA">
    <Grid ColumnDefinitions="*,400" Padding="24" ColumnSpacing="16">
        <!-- LEFT PANEL: Header + Table Grid -->
        <StackLayout Grid.Column="0" Spacing="16">
            <Label Text="Billing Center" FontSize="24" FontAttributes="Bold" TextColor="Black"/>
            <Label Text="Select a table to view and settle orders" TextColor="#6C757D" FontSize="14"/>
            <ScrollView>
                <StackLayout x:Name="TableGridContainer" Spacing="10"/>
            </ScrollView>
        </StackLayout>
        <!-- RIGHT PANEL: Order Summary -->
        <Border Grid.Column="1" BackgroundColor="White" Stroke="#DEE2E6"
                StrokeShape="RoundRectangle 12" Padding="20">
            <ScrollView>
                <StackLayout x:Name="SummaryPanel" Spacing="10">
                    <StackLayout x:Name="EmptyState" HorizontalOptions="Center" VerticalOptions="Center" Spacing="12">
                        <Label Text="₹" FontSize="48" TextColor="#DEE2E6" HorizontalOptions="Center" Margin="0,40,0,0"/>
                        <Label Text="Select a table" FontSize="16" FontAttributes="Bold" HorizontalOptions="Center"/>
                        <Label Text="Select a table from the grid to view pending orders."
                               TextColor="#6C757D" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                    </StackLayout>
                </StackLayout>
            </ScrollView>
        </Border>
    </Grid>
</ContentView>
